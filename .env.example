# Domaine public pointant vers le serveur Docker.
DOMAIN=jardin-vert-tige.fr

# Adresse e-mail utilisee par Let's Encrypt pour les notifications de certificat.
LETSENCRYPT_EMAIL=monemail

# A remplacer avant la premiere mise en ligne.
VERT_TIGE_ADMIN_PASSWORD=lemdpdemonchoix
VERT_TIGE_SECRET=genere-une-longue-valeur-aleatoire

# Optionnel: configuration du formulaire de contact.
VERT_TIGE_CONTACT_EMAIL=
VERT_TIGE_SMTP_HOST=
VERT_TIGE_SMTP_PORT=587
VERT_TIGE_SMTP_SECURITY=starttls
VERT_TIGE_SMTP_USER=
VERT_TIGE_SMTP_PASSWORD=
VERT_TIGE_SMTP_FROM=
